# Supabase Configuration
# Get these values from your Supabase dashboard: Settings > API

# Public URL (found in Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://chkulbjaexjhqzltdfth.supabase.co

# Anon Key (found in Settings > API > Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_0T-zu-ZmhPEeJTESOgZfYA_Ff0AcAr8

# Service Role Key (found in Settings > API > Project API keys > service_role)
# WARNING: This key bypasses RLS - never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin Configuration
# Email address for admin access (used for login)
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# Comma-separated list of admin emails (for multiple admins)
# NEXT_PUBLIC_ADMIN_EMAILS=admin1@example.com,admin2@example.com
